# Připojovací řetězec k Postgres databázi.
# Na Vercelu se nastaví AUTOMATICKY, když připojíš Neon databázi (viz README).
# Pro lokální vývoj sem vlož connection string z Neonu.
DATABASE_URL="postgresql://user:heslo@host/dbname?sslmode=require"

# Heslo pro přístup do aplikace (ochrana, protože web je veřejný).
# Když necháš prázdné / nenastavíš, aplikace je bez hesla.
APP_PASSWORD="zvol-si-silne-heslo"
